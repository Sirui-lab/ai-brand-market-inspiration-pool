DATABASE_URL="file:./dev.db"

# Production example for Railway with a volume mounted at /data:
# DATABASE_URL="file:/data/dev.db"
# MEDIA_CACHE_DIR="/data/media-cache"
MEDIA_CACHE_DIR=

# Optional: route Instagram server-side capture through a local VPN/proxy.
# ClashX Pro commonly uses http://127.0.0.1:7890.
INSTAGRAM_PROXY_URL=

# Optional: server-side Instagram login fallback if public profile requests are blocked.
# Keep this disabled for normal use. If it is ever enabled, use a project-owned
# capture account instead of a personal account.
INSTAGRAM_USE_LOGIN_FALLBACK=false
INSTAGRAM_SESSION_ID=
INSTAGRAM_COOKIE=

# Optional: project-owned X API bearer token for server-side recent-post capture.
# Without this, X capture only verifies whether the public profile page is reachable.
# Recommended for production because it can return public_metrics.like_count.
X_BEARER_TOKEN=

# Optional: project-owned X collector account fallback. Prefer X_BEARER_TOKEN
# when possible. Do not use a personal account.
X_AUTH_TOKEN=
X_CT0=

# Optional: project-owned LinkedIn login fallback if public company pages are blocked.
# Keep this disabled for normal use. Do not use a personal account.
LINKEDIN_USE_LOGIN_FALLBACK=false
LINKEDIN_LI_AT=
LINKEDIN_COOKIE=
