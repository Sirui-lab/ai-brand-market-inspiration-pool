    "prisma": "6.14.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "undici": "^8.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.9",
